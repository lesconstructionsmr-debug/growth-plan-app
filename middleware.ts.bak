import { createServerClient } from '@supabase/ssr'
import { NextResponse, type NextRequest } from 'next/server'

export async function middleware(request: NextRequest) {
  // Petit délai pour sync le token aux cookies
  await new Promise(r => setTimeout(r, 100))
  
  let response = NextResponse.next({ request })
  const supabase = createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    {
      cookies: {
        getAll() { return request.cookies.getAll() },
        setAll(cookiesToSet) {
          cookiesToSet.forEach(({ name, value }) => request.cookies.set(name, value))
          response = NextResponse.next({ request })
          cookiesToSet.forEach(({ name, value, options }) =>
            response.cookies.set(name, value, options)
          )
        },
      },
    }
  )
  
  const { data: { user } } = await supabase.auth.getUser()
  const publicPaths = ['/login', '/register', '/carte']
  const isPublic = publicPaths.some(p => request.nextUrl.pathname.startsWith(p))
  
  if (!user && !isPublic) {
    const url = request.nextUrl.clone()
    url.pathname = '/login'
    return NextResponse.redirect(url)
  }
  
  if (user && (request.nextUrl.pathname === '/login' || request.nextUrl.pathname === '/register')) {
    const lastAuth = request.cookies.get('_auth_time')?.value
    const now = Date.now()
    if (!lastAuth || (now - parseInt(lastAuth)) > 500) {
      const url = request.nextUrl.clone()
      url.pathname = '/dashboard'
      response.cookies.set('_auth_time', now.toString())
      return NextResponse.redirect(url)
    }
  }
  
  return response
}

export const config = {
  matcher: ['/((?!_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)'],
}